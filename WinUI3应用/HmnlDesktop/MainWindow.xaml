<Window
    x:Class="HmnlDesktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="HMNL直播讨论站"
    Width="1200"
    Height="800">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid Margin="16" CornerRadius="{StaticResource CornerRadiusMduiLgValue}" 
              Background="{ThemeResource CardBackground}" 
              BorderBrush="{ThemeResource CardBorderBrush}" 
              BorderThickness="1">
            <Grid.Effect>
                <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.1" Direction="270" ShadowDepth="4" />
            </Grid.Effect>
            
            <NavigationView x:Name="MainNavigation" 
                           IsBackEnabled="False" 
                           IsSettingsVisible="True"
                           Background="Transparent">
                <NavigationView.MenuItems>
                    <NavigationViewItem Icon="Home" Content="首页" Tag="home" />
                    <NavigationViewItem Icon="Post" Content="帖子" Tag="posts" />
                    <NavigationViewItem Icon="Chat" Content="聊天" Tag="chat" />
                    <NavigationViewItem Icon="Video" Content="直播" Tag="live" />
                    <NavigationViewItem Icon="Robot" Content="AI对话" Tag="ai" />
                    <NavigationViewItem Icon="Repair" Content="工具箱" Tag="tools" />
                </NavigationView.MenuItems>

                <Frame x:Name="ContentFrame">
                    <Frame.ContentTransitions>
                        <TransitionCollection>
                            <NavigationThemeTransition />
                        </TransitionCollection>
                    </Frame.ContentTransitions>
                </Frame>
            </NavigationView>
        </Grid>
    </Grid>
</Window>
